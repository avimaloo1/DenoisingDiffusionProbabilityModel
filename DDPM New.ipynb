# Function to train the model
def train_the_model():
    epochs = 200
    learning_rate = 0.001
    optimizer = optim.Adam(model.parameters(), lr=learning_rate)
    criterion = nn.MSELoss()

    # Print model and training configuration
    print(f"Number of epochs: {epochs}")
    print(f"Learning rate: {learning_rate}")
    print(f"Loss function: Mean Squared Error")
    print(f"Optimizer: Adam")
    print(f"Number of parameters: {sum(p.numel() for p in model.parameters())}")

    start_time = time.time()

    for epoch in range(epochs):
        # Shuffle samples
        X_shuffled = image_tensor.repeat(samples, 1, 1, 1)  # Repeat to create a dataset of the desired size
        X_shuffled = X_shuffled[torch.randperm(X_shuffled.size(0))]

        batch_size = 100
        for i in range(0, samples, batch_size):
            sum_loss = 0

            # Process batches
            batch_X = X_shuffled[i:i + batch_size]
            for t in torch.randperm(T):
                # Add Gaussian noise
                target = torch.randn_like(batch_X)
                x_t = (
                    torch.sqrt(alpha_bar[t]) * batch_X
                    + torch.sqrt(1 - alpha_bar[t]) * target
                )
                # Calculate model output and loss
                output = model(x_t, torch.tensor([t] * batch_size, device=device))
                loss = criterion(output, target)
                optimizer.zero_grad()
                loss.backward()
                optimizer.step()
                sum_loss += loss.item()

            avg_loss = sum_loss / T

            if epoch % 10 == 0:
                print(f"Epoch {epoch}, Loss: {avg_loss:.4f}, Elapsed time: {time.time() - start_time:.2f} seconds")

train_the_model()

